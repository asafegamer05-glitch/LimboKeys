{
  "name": "limbo-keys",
  "version": "1.0.0",
  "main": "main.js",
  "author": "Asaf",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win portable"
  },
  "build": {
    "appId": "com.limbo.keys",
    "productName": "Limbo Keys",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "*.html",
      "images/**/*",
      "sounds/**/*",
      "icon.ico",
      "node_modules/**/*"
    ],
    "win": {
      "target": "portable",
      "icon": "icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "portable": {
      "artifactName": "${productName}.exe"
    },
    "compression": "maximum"
  },
  "devDependencies": {
    "electron": "30.0.0",
    "electron-builder": "^26.8.1"
  }
}